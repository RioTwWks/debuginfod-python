# debuginfod-python production environment (Astra Linux / RedOS)
DEBUGINFOD_DATABASE_URL=postgresql://debuginfod:password@localhost/debuginfod
DEBUGINFOD_INPUT_PATH=/var/lib/debuginfod/incoming
DEBUGINFOD_WORK_PATH=/var/lib/debuginfod/store
DEBUGINFOD_SCAN_PATH=/var/lib/debuginfod/store
DEBUGINFOD_DEDUP_PROJECTS=QuikServer,Front
DEBUGINFOD_DEDUP_ENABLED=true
DEBUGINFOD_BLOB_DIR=/var/lib/debuginfod/blobs
DEBUGINFOD_RECONSTRUCT_CACHE_DIR=/var/lib/debuginfod/reconstruct-cache
DEBUGINFOD_PORT=8003
DEBUGINFOD_RESCAN_INTERVAL=3600
DEBUGINFOD_XDELTA3_PATH=xdelta3
DEBUGINFOD_SEVEN_ZIP_PATH=7z
DEBUGINFOD_ADMIN_KEY=
DEBUGINFOD_LOG_LEVEL=info
DEBUGINFOD_LOG_DIR=/var/log/debuginfod
