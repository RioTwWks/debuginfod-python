DEBUGINFOD_DB_PATH=debuginfod.sqlite
DEBUGINFOD_SCAN_PATH=.
DEBUGINFOD_PORT=8003
DEBUGINFOD_CACHE_DIR=.debuginfod-cache
DEBUGINFOD_RESCAN_INTERVAL=3600
DEBUGINFOD_SCAN_WORKERS=4
# Лимиты памяти при scan/dedup (0 = без лимита для max_ram/max_swap)
DEBUGINFOD_MEMORY_MAX_RAM_MB=6144
DEBUGINFOD_MEMORY_MAX_SWAP_MB=2048
DEBUGINFOD_MEMORY_MIN_AVAILABLE_MB=1024
# DWARF-источники не извлекаются из ELF крупнее этого порога (экономит RAM)
DEBUGINFOD_SCAN_DWARF_MAX_MB=128
DEBUGINFOD_XDELTA_PATH=xdelta3
DEBUGINFOD_LOG_LEVEL=info
DEBUGINFOD_UI_ENABLED=true
DEBUGINFOD_BENCHMARK_GO_URL=http://localhost:8002
DEBUGINFOD_BENCHMARK_TESTDATA=testdata/versions

# Quik .debug deduplication (same model as debuginfod-go)
# DEBUGINFOD_DEDUP_ENABLED=true
# DEBUGINFOD_DEDUP_PROJECTS=QuikServer,Front
# DEBUGINFOD_DEDUP_WORKERS=4
# DEBUGINFOD_DEDUP_STRATEGY=xdelta-decompress-dwz
# DEBUGINFOD_DEDUP_COMPRESS_BASE=true
# DEBUGINFOD_DWZ_PATH=dwz
# DEBUGINFOD_OBJCOPY_PATH=objcopy
# DEBUGINFOD_DATABASE_URL=postgresql://user:pass@localhost/debuginfod

# Ключ для POST /admin/rescan на debuginfod-go при бенчмарке
# DEBUGINFOD_BENCHMARK_GO_ADMIN_KEY=
# DEBUGINFOD_BENCHMARK_PY_ADMIN_KEY=
