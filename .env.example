DEBUGINFOD_DB_PATH=debuginfod.sqlite
DEBUGINFOD_SCAN_PATH=.
DEBUGINFOD_PORT=8003
DEBUGINFOD_BLOB_DIR=.debuginfod-blobs
DEBUGINFOD_RECONSTRUCT_CACHE_DIR=.debuginfod-reconstruct-cache
DEBUGINFOD_RESCAN_INTERVAL=3600
DEBUGINFOD_DELTA_MIN_RATIO=0.85
DEBUGINFOD_XDELTA3_PATH=xdelta3
DEBUGINFOD_LOG_LEVEL=info
DEBUGINFOD_UI_ENABLED=true
DEBUGINFOD_BENCHMARK_GO_URL=http://localhost:8002
DEBUGINFOD_BENCHMARK_TESTDATA=testdata/versions
# Ключ для POST /admin/rescan на debuginfod-go при бенчмарке (тот же, что DEBUGINFOD_ADMIN_KEY у Go)
# DEBUGINFOD_BENCHMARK_GO_ADMIN_KEY=
# DEBUGINFOD_BENCHMARK_PY_ADMIN_KEY=  # по умолчанию = DEBUGINFOD_ADMIN_KEY
